# Copy to `.env.local` for local dev (never commit real secrets).

# Required for wallet modal (WalletConnect / AppKit).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Default chain for the adapter (84532 = Base Sepolia).
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532

# --- Base mainnet (8453) ---
NEXT_PUBLIC_BASE_USDC_ADDRESS=
NEXT_PUBLIC_BASE_VAULT_FACTORY_ADDRESS=
NEXT_PUBLIC_BASE_VAULT_PRIME_ADDRESS=
NEXT_PUBLIC_BASE_VAULT_GROWTH_ADDRESS=

# --- Base Sepolia (84532) ---
NEXT_PUBLIC_BASE_SEPOLIA_USDC_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_VAULT_FACTORY_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_VAULT_PRIME_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_VAULT_GROWTH_ADDRESS=

# --- Sepolia legacy (11155111) ---
NEXT_PUBLIC_SEPOLIA_USDC_ADDRESS=
NEXT_PUBLIC_SEPOLIA_VAULT_ADDRESS=
